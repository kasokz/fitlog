{
	"name": "@repo/ui",
	"version": "0.0.1",
	"type": "module",
	"imports": {
		"#*": "./src/*"
	},
	"exports": {
		"./utils": "./src/utils.ts",
		"./components/ui/*": {
			"types": "./src/components/ui/*/index.ts",
			"svelte": "./src/components/ui/*/index.ts",
			"default": "./src/components/ui/*/index.ts"
		},
		"./components/*": {
			"types": "./src/components/*/index.ts",
			"svelte": "./src/components/*/index.ts",
			"default": "./src/components/*/index.ts"
		},
		"./globals.css": "./src/globals.css"
	},
	"peerDependencies": {
		"layerchart": "^2.0.0-next.0",
		"svelte": "^5.0.0"
	},
	"dependencies": {
		"@lucide/svelte": "^0.562.0",
		"@repo/typescript-config": "workspace:*",
		"@tailwindcss/vite": "^4.1.17",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"embla-carousel-svelte": "^8.6.0",
		"formsnap": "^2.0.1",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.30.0",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vaul-svelte": "1.0.0-next.7",
		"vite": "^7.2.6"
	},
	"keywords": [
		"svelte"
	]
}
