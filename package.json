{
	"name": "my-app",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"test": "turbo run test",
		"lint": "turbo run lint",
		"paraglide:compile": "turbo run paraglide:compile",
		"format": "prettier --write .",
		"check": "turbo run check"
	},
	"devDependencies": {
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"turbo": "^2.8.16",
		"typescript": "5.9.2"
	},
	"packageManager": "pnpm@10.30.3",
	"engines": {
		"node": ">=18"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		],
		"overrides": {
			"sharp": "0.34.1"
		}
	}
}
