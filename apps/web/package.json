{
	"name": "web",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"check": "paraglide-js compile --outdir src/lib/paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev --port 5174",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"paraglide:compile": "paraglide-js compile --outdir src/lib/paraglide"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.6.0",
		"@lucide/svelte": "^0.562.0",
		"@repo/ui": "workspace:*",
		"@sveltejs/adapter-node": "^5.5.1",
		"@sveltejs/enhanced-img": "^0.10.3",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/vite": "^4.1.17",
		"mode-watcher": "^1.1.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"vite": "^7.2.6",
		"vite-plugin-devtools-json": "^1.0.0"
	}
}
