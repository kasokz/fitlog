# Fastlane Environment Variables
#
# This file documents all required environment variables for fastlane automation.
# Copy this to .env and fill in actual values (never commit .env to git).
#
# Learn more: https://docs.fastlane.tools/best-practices/keys/

# ============================================================================
# iOS Environment Variables
# ============================================================================

# Apple ID (email address) for App Store Connect
# Where to find: The email you use to log into https://appstoreconnect.apple.com
# Example: APPLE_ID=developer@pokeresque.com
APPLE_ID=

# Apple Developer Team ID (10-character alphanumeric)
# Where to find: https://developer.apple.com/account/#/membership
# Look for "Team ID" field
# Example: FASTLANE_TEAM_ID=A1B2C3D4E5
FASTLANE_TEAM_ID=

# App Store Connect Team ID (may differ from Developer Portal Team ID)
# Where to find: App Store Connect > Users and Access > Keys
# Only needed if you're part of multiple App Store Connect teams
# Example: FASTLANE_ITC_TEAM_ID=123456789
FASTLANE_ITC_TEAM_ID=

# App Store Connect API Key ID (for API-based authentication)
# Where to find: App Store Connect > Users and Access > Keys > Create/View Key
# Recommended for CI/CD to avoid 2FA issues
# Example: FASTLANE_KEY_ID=ABCD1234
FASTLANE_KEY_ID=

# App Store Connect API Issuer ID
# Where to find: Same page as API Key, in the "Issuer ID" field at top
# Example: FASTLANE_ISSUER_ID=12345678-1234-1234-1234-123456789012
FASTLANE_ISSUER_ID=

# Path to App Store Connect API Key (.p8 file)
# Where to find: Download when creating API key (can only download once!)
# Example: FASTLANE_KEY_FILEPATH=./fastlane/keys/AuthKey_ABCD1234.p8
FASTLANE_KEY_FILEPATH=

# Match repository URL (for certificate management in Phase 46+)
# Where to create: Private git repository for storing encrypted certificates
# Example: MATCH_GIT_URL=https://github.com/company/certificates.git
MATCH_GIT_URL=

# Match password (for encrypting/decrypting certificates)
# Where to set: Choose a strong password, share securely with team
# Example: MATCH_PASSWORD=super-secret-password-123
MATCH_PASSWORD=

# Match Git Basic Authorization (for HTTPS git URLs with personal access token)
# When to use: If MATCH_GIT_URL uses HTTPS and you're not using SSH keys
# How to generate:
#   1. Create GitHub personal access token: https://github.com/settings/tokens
#   2. Grant "repo" scope (full control of private repositories)
#   3. Run: echo -n "github_username:ghp_yourtoken" | base64
#   4. Paste the base64 output below
# Example: MATCH_GIT_BASIC_AUTHORIZATION=dXNlcm5hbWU6Z2hwX3Rva2VuMTIzNDU2Nzg5MA==
MATCH_GIT_BASIC_AUTHORIZATION=

# ============================================================================
# Android Environment Variables
# ============================================================================

# --------------------------------------------------------------------------
# Android Keystore Configuration
# --------------------------------------------------------------------------
# Generate keystore (one-time, from apps/mobile/android/app/):
#   keytool -genkeypair -v -storetype PKCS12 \
#     -keystore my-release-key.keystore -alias my-key-alias \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# CRITICAL: Back up keystore to 2+ locations! Loss = cannot update app on Play Store
# See: fastlane/docs/KEYSTORE_BACKUP_STRATEGY.md

# Path to keystore file (relative to android/app/ directory)
# Where to find: Create using keytool command above
# Example: MYAPP_UPLOAD_STORE_FILE=my-release-key.keystore
MYAPP_UPLOAD_STORE_FILE=

# Keystore alias (set during keytool generation)
# Where to find: The -alias value used in keytool command
# Example: MYAPP_UPLOAD_KEY_ALIAS=my-key-alias
MYAPP_UPLOAD_KEY_ALIAS=

# Keystore password (set during keytool generation)
# Where to find: Password manager (after saving during generation)
# Example: MYAPP_UPLOAD_STORE_PASSWORD=your-secure-password
MYAPP_UPLOAD_STORE_PASSWORD=

# Key password (set during keytool generation, can be same as keystore password)
# Where to find: Password manager (after saving during generation)
# Example: MYAPP_UPLOAD_KEY_PASSWORD=your-secure-password
MYAPP_UPLOAD_KEY_PASSWORD=

# --------------------------------------------------------------------------
# Google Play Console Service Account
# --------------------------------------------------------------------------
# Required for fastlane to upload to Play Console.
# See: fastlane/docs/SERVICE_ACCOUNT_SETUP.md for step-by-step guide

# Path to Google Play service account JSON key
# Where to find: Google Cloud Console > IAM & Admin > Service Accounts
# Create service account > Create Key > JSON
# Learn more: https://docs.fastlane.tools/getting-started/android/setup/
# Example: GOOGLE_PLAY_JSON_KEY_PATH=./fastlane/keys/google-play-service-account.json
GOOGLE_PLAY_JSON_KEY_PATH=
